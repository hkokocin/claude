{
  "permissions": {
    "allow": [
      "Read(~/docs/**)",
      "Read(~/.claude/shared/**)",
      "Read(~/projects/testing/curl/**)",
      "Bash(cat:*)",
      "Bash(fd:*)",
      "Bash(docker compose:*)",
      "Bash(docker logs:*)",
      "Bash(docker ps:*)",
      "Bash(rg:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr view:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(pip index:*)",
      "Bash(git merge:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(poetry run:*)",
      "Bash(poetry add:*)",
      "Bash(poetry install:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform init:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform validate:*)",
      "Bash(set -a && source .env && poetry run:*)",
      "mcp__plugin_asana_asana__*"
    ],
    "deny": ["Read(./.env)", "Read(./.env.*)", "Bash(terraform apply:*),"],
    "additionalDirectories": [
      "~/docs",
      "~/.claude/shared",
      "~/projects/testing/curl"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'REMINDER: Follow TDD.'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/Cellar/claude-notify/1.1.0/lib/claude-notify/core/notifier.sh notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/Cellar/claude-notify/1.1.0/lib/claude-notify/core/notifier.sh stop"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "asana@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "terraform-code-generation@hashicorp": false,
    "terraform-module-generation@hashicorp": false
  },
  "alwaysThinkingEnabled": true,
  "autoApproveCommands": false
}
