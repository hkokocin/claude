{
  "permissions": {
    "allow": [
      "Read(~/docs/**)",
      "Read(~/.claude/shared/**)",
      "Bash(fd:*)",
      "Bash(docker compose:*)",
      "Bash(docker logs:*)",
      "Bash(docker ps:*)",
      "Bash(rg:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git log:*)",
      "Bash(git rev-parse:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(pip index:*)",
      "Bash(poetry run:*)",
      "Bash(poetry add:*)",
      "Bash(poetry install:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform init:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform validate:*)",
      "Bash(set -a && source .env && poetry run:*)",
      "mcp__plugin_asana_asana__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(terraform apply:*),"
    ],
    "additionalDirectories": [
      "~/docs",
      "~/.claude/shared"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'REMINDER: Follow TDD. Tests before implementation. Use /test then /implement. Never change tests to make them pass.'"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/commit-on-clear.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/Cellar/claude-notify/1.1.0/lib/claude-notify/core/notifier.sh notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/Cellar/claude-notify/1.1.0/lib/claude-notify/core/notifier.sh stop"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "asana@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "terraform-code-generation@hashicorp": false,
    "terraform-module-generation@hashicorp": false
  },
  "alwaysThinkingEnabled": true,
  "autoApproveCommands": false
}
